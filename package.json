{
  "name": "@causa/workspace-terraform",
  "version": "0.10.0",
  "description": "The Causa workspace module providing functionalities for infrastructure projects coded in Terraform.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/causa-io/workspace-module-terraform.git"
  },
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "LICENSE.md",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf ./dist",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node transform-schemas.mjs",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --no-warnings=ExperimentalWarning\" jest",
    "test:cov": "npm run test -- --coverage",
    "typecheck": "tsc --noEmit",
    "generateConfigurationSchemas": "cs model genCode && perl -pi -e 's|\\@causa/runtime|\\@causa/workspace/validation|g' src/configurations/generated.ts"
  },
  "dependencies": {
    "@causa/workspace": ">= 0.23.0 < 1.0.0",
    "@causa/workspace-core": ">= 0.30.0 < 1.0.0",
    "globby": "^16.2.0",
    "pino": "^10.3.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@tsconfig/node22": "^22.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/semver": "^7.7.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
